# CrestsX Frontend Environment Variables

# MCP Server API Configuration (for DevOps Agent deployment)
NEXT_PUBLIC_API_URL=https://api.exchange.crestsx.com
NEXT_PUBLIC_WS_URL=wss://api.exchange.crestsx.com/stream

# Backend API Configuration (legacy)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Solana Network Configuration
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_CHAIN_ID=devnet

# Additional Solana Config (legacy)
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# x402 Payment Configuration
NEXT_PUBLIC_X402_ENABLED=true
NEXT_PUBLIC_PAYMENT_TOKEN=USDC

# Application Configuration
NEXT_PUBLIC_APP_NAME=CrestsX
NEXT_PUBLIC_APP_URL=https://exchange.crestsx.com

# Feature Flags
NEXT_PUBLIC_ENABLE_AIRDROP=true
NEXT_PUBLIC_ENABLE_REFERRALS=true

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Social Links
NEXT_PUBLIC_TWITTER=https://twitter.com/crestsx
NEXT_PUBLIC_DISCORD=https://discord.gg/crestsx
NEXT_PUBLIC_GITHUB=https://github.com/AnodazTeam/crestsx-frontend

# Local Development Override (uncomment for local MCP server)
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_WS_URL=ws://localhost:8080/stream
