# CrestsX Frontend Environment Variables

# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/stream

# Solana Network Configuration
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# x402 Payment Configuration
NEXT_PUBLIC_X402_ENABLED=true
NEXT_PUBLIC_PAYMENT_TOKEN=USDC

# Application Configuration
NEXT_PUBLIC_APP_NAME=CrestsX
NEXT_PUBLIC_APP_URL=https://crestsx.com

# Feature Flags
NEXT_PUBLIC_ENABLE_AIRDROP=true
NEXT_PUBLIC_ENABLE_REFERRALS=true

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_SENTRY_DSN=

# Social Links
NEXT_PUBLIC_TWITTER=https://twitter.com/crestsx
NEXT_PUBLIC_DISCORD=https://discord.gg/crestsx
NEXT_PUBLIC_GITHUB=https://github.com/AnodazTeam/crestsx-frontend
