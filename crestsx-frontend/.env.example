# CrestsX Frontend Environment Variables
# Copy to .env.local for local development

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://api.crestsx.com
NEXT_PUBLIC_WS_URL=wss://api.crestsx.com/stream

# Solana Configuration
NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_MCP_URL=https://api.crestsx.com/mcp

# App Configuration
NEXT_PUBLIC_APP_URL=https://crestsx.com
NEXT_PUBLIC_APP_NAME=CrestsX

# Optional: Feature Flags
# NEXT_PUBLIC_REFERRAL_ENABLED=true
# NEXT_PUBLIC_x402_ENABLED=true
